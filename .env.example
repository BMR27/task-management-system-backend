DATABASE_URL="postgresql://user:password@localhost:5432/tickets?schema=public"

JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

FRONTEND_URL="http://localhost:3000"
NODE_ENV="production"
PORT=4000
UPLOADS_DIR="./uploads"

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM="NEXT OS Help Desk <no-reply@example.com>"

# Correo entrante (webhook de Resend) — ver src/inbound-email/
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
MAIL_DOMAIN="example.com"

# Cola de procesamiento de correos entrantes (BullMQ)
REDIS_URL="redis://localhost:6379"
